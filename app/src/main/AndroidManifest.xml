<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL"/>
    <uses-permission android:name="android.permission.VIBRATE"/>
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"/>
    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SHEiled">
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${google_maps_key}" />

        <activity
            android:name=".ui.auth.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <service
            android:name=".ui.sos.SOSTileService"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true"
            android:label="SOS"
            android:icon="@drawable/ic_sos">

            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>
        <service
            android:name=".ui.sos.SensorService"
            android:exported="false"
            android:foregroundServiceType="location|phoneCall" />
        <service
            android:name=".ui.sos.LiveTrackingService"
            android:foregroundServiceType="location"
            android:exported="false"/>


        <service
            android:name=".safety.SafetyForegroundService"
            android:foregroundServiceType="location"
            android:exported="false"/>
        <service
            android:name=".ui.sos.SOSForegroundService"
            android:foregroundServiceType="location"
            android:exported="false"/>

        <activity android:name=".ui.auth.AuthChoiceActivity"/>
        <activity android:name=".ui.dashboard.DashBoardActivity"/>
        <activity android:name=".ui.auth.ForgotPasswordActivity"/>
        <activity android:name=".ui.auth.LoginActivity"/>
        <activity android:name=".ui.auth.RegisterActivity"/>
        <activity android:name=".ui.auth.SettingsActivity" />
        <activity
            android:name=".ui.dashboard.SelectLocationActivity"
            android:exported="false"/>
<activity android:name=".ui.dashboard.CabBookActivity"/>
        <activity android:name=".ui.dashboard.DriverDashboardActivity"/>
        <activity android:name=".ui.auth.DriverRegisterActivity"/>
        <activity android:name=".safety.SafeModeActivity"/>
        <activity android:name=".ui.menubook.periodtracker.PeriodTrackerActivity"/>
        <activity
            android:name=".ui.dashboard.DriverNavigationActivity"
            android:exported="false" />
        <activity
            android:name=".ui.dashboard.DriverFeedbackActivity"
            android:exported="false" />
        <activity
            android:name=".ui.dashboard.UserRideHistoryActivity"
            android:exported="false" />
        <activity
            android:name=".ui.dashboard.RatingActivity"
            android:exported="false" />
        <activity
            android:name=".ui.dashboard.PaymentActivity"
            android:exported="false" />
        <activity
            android:name=".ui.dashboard.DriverPaymentActivity"
            android:exported="false" />
        <activity
            android:name=".ui.dashboard.RideTrackingActivity"
            android:exported="false" />
        <activity
            android:name=".ui.dashboard.CabDashboardActivity"/>
        <activity
            android:name=".ui.menubook.BrowseProductsActivity"/>
        <activity
            android:name=".ui.menubook.CartActivity"/>
        <activity
            android:name=".ui.menubook.CheckoutActivity"/>
        <activity
            android:name=".ui.menubook.OrdersActivity"/>
        <activity
            android:name=".ui.menubook.PlaceOrderActivity"/>
        <activity
            android:name=".ui.menubook.ProductPaymentActivity"/>
        <activity
            android:name=".ui.menubook.OrderTrackingActivity"/>




        <receiver
            android:name=".ui.menubook.periodtracker.utils.PeriodReceiver"
            android:exported="false"/>
        <receiver
            android:name=".ui.sos.ReactivateService"
            android:exported="false" />
        <receiver
        android:name=".ui.menubook.periodtracker.utils.ReminderReceiver"/>
        <receiver
            android:name=".ui.menubook.periodtracker.utils.PeriodConfirmationReceiver"
            android:exported="false" />
    </application>

</manifest>
