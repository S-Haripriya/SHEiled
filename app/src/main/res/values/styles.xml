<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="BottomNavButton" parent="Widget.Material3.Button">

        <!-- Size -->
        <item name="android:layout_width">56dp</item>
        <item name="android:layout_height">56dp</item>

        <!-- Shape -->
        <item name="cornerRadius">28dp</item>

        <!-- Background -->
        <item name="android:backgroundTint">@color/white</item>
        <item name="android:elevation">2dp</item>


        <!-- Icon only -->
        <item name="iconSize">24dp</item>
        <item name="iconTint">@color/icon_black</item>
        <item name="android:textColor">@android:color/transparent</item>

        <!-- Material 3 replacement for insets -->
        <item name="android:padding">0dp</item>

        <!-- Ripple -->
        <item name="rippleColor">#33FF8FB1</item>

    </style>
    <style name="ProfileRow">
        <item name="android:orientation">horizontal</item>
        <item name="android:padding">12dp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="ProfileIcon">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:tint">@color/pink_500</item>
    </style>

    <style name="ProfileText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">12dp</item>
        <item name="android:textSize">16sp</item>

    </style>
        <style name="CircleImage" parent="ShapeAppearance.Material3.SmallComponent">>
            <item name="cornerSize">50%</item>
        </style>
    <style name="WeekDayStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#7C3AED</item>
        <item name="android:textSize">14sp</item>
    </style>

</resources>
