<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Search Bar -->

    <LinearLayout
        android:id="@+id/searchBar"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_margin="12dp"
        android:background="@drawable/search_bg"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:elevation="6dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView
            android:id="@+id/tvSearchHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍 Where do you want to go?"
            android:textSize="15sp"
            android:textColor="#777"/>
    </LinearLayout>
    <!-- FULL SCREEN MAP -->
    <FrameLayout
        android:id="@+id/mapContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/searchBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- OVERLAY PANEL (Initially Hidden) -->
    <LinearLayout
        android:id="@+id/placesPanel"
        android:layout_width="0dp"
        android:layout_height="350dp"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:elevation="12dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/placesLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nearby Safe Havens"
            android:textStyle="bold"
            android:padding="12dp"/>

        <ScrollView
            android:id="@+id/placeScroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/safePlacesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp"/>
        </ScrollView>

    </LinearLayout>

    <!-- Share Button -->
    <ImageButton
        android:id="@+id/btnShareFloat"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/round_button"
        android:src="@drawable/ic_share"
        android:elevation="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_margin="16dp"/>

    <!-- Nearby Button -->
    <ImageButton
        android:id="@+id/btnNearbyFloat"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/round_button"
        android:src="@drawable/ic_safe"
        android:elevation="20dp"
        app:layout_constraintBottom_toTopOf="@id/btnShareFloat"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="16dp"
        android:layout_marginStart="16dp"/>

    <!-- Cab Button -->
    <ImageButton
        android:id="@+id/btnStopShare"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/red_circle_bg"
        android:src="@drawable/ic_stop"
        android:elevation="20dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/btnSafeMode"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp"
        android:layout_marginEnd="16dp"/>
    <ImageButton
        android:id="@+id/btnSafeMode"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/round_button"
        android:src="@drawable/icon_safe"
        android:elevation="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="16dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>
